{
  "name": "playwright-automation-framework",
  "version": "1.0.0",
  "description": "A playwright automation framework built with typescript",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:report": "allure generate ./allure-results --clean -o ./allure-report",
    "test:report:open": "allure open ./allure-report",
    "docker:build": "docker build -t playwright-automation-framework .",
    "docker:test": "docker run --rm -v $PWD/allure-results:/app/allure-results playwright-automation-framework"
  },
  "keywords": ["Playwright", "Typescript", "Automation"],
  "author": "Patrick Azu",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.5",
    "allure-commandline": "^2.29.0",
    "tsconfig-paths": "^4.2.0"
  },
  "dependencies": {
    "allure-playwright": "^3.6.0",
    "qa-faker-factory": "^1.0.1"
  }
}
